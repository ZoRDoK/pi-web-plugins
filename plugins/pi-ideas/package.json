{
  "name": "@zordok/pi-web-plugin-ideas",
  "version": "0.1.1",
  "description": "Workspace Ideas plugin for Pi Web.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZoRDoK/pi-web-plugins.git",
    "directory": "plugins/pi-ideas"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "package.json",
    "README.md"
  ],
  "piWeb": {
    "plugins": [
      {
        "id": "workspace-ideas",
        "module": "dist/pi-web-plugin.js"
      }
    ]
  },
  "keywords": [
    "pi-package",
    "pi-web",
    "pi-web-plugin",
    "ideas"
  ]
}
